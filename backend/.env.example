# OPTIONAL — Google Places + PageSpeed + (preferred) geocoding. Leave empty if you use Geoapify or OSM-only.
GOOGLE_PLACES_API_KEY=

# OPTIONAL — Geoapify Places (free tier after signup): https://www.geoapify.com/ — good Google Places alternative
GEOAPIFY_API_KEY=

# FREE AI — at least one of Gemini or Ollama
GEMINI_API_KEY=
OLLAMA_HOST=http://localhost:11434

# OPTIONAL — Yelp discovery
YELP_API_KEY=

# OPTIONAL — Facebook Graph search (Pages)
FACEBOOK_ACCESS_TOKEN=

# EMAIL DIGEST
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
DIGEST_RECIPIENT=

# CONFIG
DATABASE_URL=sqlite:///./leads.db
SCREENSHOT_DIR=./screenshots
AUDIO_DIR=./audio
DEFAULT_LOCATION=Geneva, IL
DEFAULT_RADIUS_MILES=15
MAX_CONCURRENT_SCRAPERS=5
SCAN_SCHEDULE_ENABLED=true
# Local + Vercel (add your custom domain when you have one)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://frontend-two-taupe-12.vercel.app,https://frontend-hi8q12wtt-linkboreds-projects.vercel.app
